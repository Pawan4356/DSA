689. Maximum Sum of 3 Non-Overlapping Subarrays

Given an integer array nums and an integer k, find three non-overlapping subarrays of length k with maximum sum and return them.
Return the result as a list of indices representing the starting position of each interval (0-indexed). 
If there are multiple answers, return the lexicographically smallest one.


Example 1:
Input: nums = [1,2,1,2,6,7,5,1], k = 2
Output: [0,3,5]
Explanation: Subarrays [1, 2], [2, 6], [7, 5] correspond to the starting indices [0, 3, 5].
We could have also taken [2, 1], but an answer of [1, 3, 5] would be lexicographically larger.

Example 2:
Input: nums = [1,2,1,2,1,2,1,2,1], k = 2
Output: [0,2,4]

=====Window Approach=====
=====Crying Emoji=====

class Solution {
    private int[][] dp = new int[20001][4];

    private int helper(int[] sum, int k, int idx, int rem) {
        if (rem == 0) return 0; // Base case: No more subarrays to pick
        if (idx >= sum.length) return Integer.MIN_VALUE; // Out of bounds

        if (dp[idx][rem] != -1) return dp[idx][rem]; // Use memoized value

        int take = sum[idx] + helper(sum, k, idx + k, rem - 1); // Take current subarray
        int not_take = helper(sum, k, idx + 1, rem); // Skip current subarray

        dp[idx][rem] = Math.max(take, not_take); // Memoize result
        return dp[idx][rem];
    }

    private void solve(int[] sum, int k, int idx, int rem, int[] indices, int pos) {
        if (rem == 0 || idx >= sum.length) return; // Base case

        int take = sum[idx] + helper(sum, k, idx + k, rem - 1); // Calculate "take"
        int not_take = helper(sum, k, idx + 1, rem); // Calculate "not_take"

        if (take >= not_take) { // Choose the better option
            indices[pos] = idx; // Store current index
            solve(sum, k, idx + k, rem - 1, indices, pos + 1); // Recur for remaining
        } else {
            solve(sum, k, idx + 1, rem, indices, pos); // Recur without taking
        }
    }

    public int[] maxSumOfThreeSubarrays(int[] nums, int k) {
        for (int[] row : dp) {
            Arrays.fill(row, -1); // Initialize dp with -1
        }

        int n = nums.length - k + 1; // Number of valid windows
        int[] sum = new int[n];
        int winsum = 0;

        // Sliding window sum calculation
        for (int i = 0; i < nums.length; i++) {
            winsum += nums[i];
            if (i >= k - 1) {
                sum[i - k + 1] = winsum;
                winsum -= nums[i - k + 1]; // Slide the window
            }
        }

        int[] indices = new int[3]; // To store result indices
        solve(sum, k, 0, 3, indices, 0);
        return indices;
    }
}