=====Optimal=====

class Solution {
    public int leastInterval(char[] tasks, int n) {
        int[] freq = new int[26];
        for (char c : tasks) {
            freq[c - 'A']++;
        }
        Arrays.sort(freq);
        int maxfreq = freq[25];
        int samemaxfreq = 0;
        for (int i : freq) {
            if (i == maxfreq) samemaxfreq++;
        }
        return Math.max((maxfreq - 1) * (n + 1) + samemaxfreq, tasks.length);
    }
}