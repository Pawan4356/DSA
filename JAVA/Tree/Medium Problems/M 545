545. Tree Boundary Traversal

class Solution {
    List<Integer> list = new ArrayList<>();

    public List<Integer> boundary(TreeNode root) {
        if (root == null)
            return list;
        if (isLeaf(root))
            return new ArrayList<>(Arrays.asList(root.val));
        list.add(root.val);
        leftB(root.left);
        leaf(root);
        rightB(root.right);
        return list;
    }

    private void leftB(TreeNode root) {
        TreeNode curr = root;
        while (curr != null) {
            if (!isLeaf(curr))
                list.add(curr.val);
            if (curr.left != null)
                curr = curr.left;
            else
                curr = curr.right;
        }
    }

    private void rightB(TreeNode root) {
        TreeNode curr = root;
        List<Integer> temp = new ArrayList<>();
        while (curr != null) {
            if (!isLeaf(curr))
                temp.add(curr.val);
            if (curr.right != null)
                curr = curr.right;
            else
                curr = curr.left;
        }
        for (int i = temp.size() - 1; i >= 0; i--) {
            list.add(temp.get(i));
        }
    }

    private void leaf(TreeNode root) {
        if (isLeaf(root))
            list.add(root.val);
        if (root.left != null)
            leaf(root.left);
        if (root.right != null)
            leaf(root.right);
    }

    private boolean isLeaf(TreeNode root) {
        return root.left == null && root.right == null;
    }
}