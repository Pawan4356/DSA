class Solution {
    public List<String> fullJustify(String[] words, int maxWidth) {
        int currll = 0;
        List<String> result = new ArrayList<>();
        List<String> currLine = new ArrayList<>();  
        for (String word : words) {
            if (currll + word.length() + currLine.size() > maxWidth) {
                result.add(justifyLine(currLine, currll, maxWidth));
                currLine.clear();
                currll = 0;
            }
            currLine.add(word);
            currll += word.length();
        }
        if (!currLine.isEmpty()) result.add(leftJustify(currLine, maxWidth));
        return result;
    }
    private String justifyLine(List<String> currLine, int currll, int maxWidth) {
        int spaceCount = maxWidth - currll;
        int gaps = currLine.size() - 1;
        if (gaps == 0) {
            return leftJustify(currLine, maxWidth);
        }
        int spacepgap = spaceCount / gaps;
        int extra = spaceCount % gaps;
        StringBuilder line = new StringBuilder();
        for (int i = 0; i < currLine.size(); i++) {
            line.append(currLine.get(i));
            if (i < gaps) {
                int spaces = spacepgap + (i < extra ? 1 : 0);
                line.append(" ".repeat(spaces));
            }
        }
        return line.toString();
    }
    private String leftJustify(List<String> currLine, int maxWidth) {
        StringBuilder line = new StringBuilder(String.join(" ", currLine));
        while (line.length() < maxWidth) {
            line.append(" ");
        }
        return line.toString();
    }
}