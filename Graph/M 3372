    private int dfs(int currNode, HashMap<Integer, List<Integer>> adj, int k, int currParent) {
        if (k < 0) return 0;
        int count = 1; // Count the target nodes.
        for (int node : adj.get(currNode)) {
            if (node != currParent) count += dfs(node, adj, k - 1, currNode);
        }
        return count;
    }
